{
  "name": "ssq-ui",
  "version": "0.0.1",
  "description": "A Vue 3 + TypeScript component library with overlay foundation, on-demand styles, and runtime theming.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "author": "Miss-sang",
  "homepage": "https://miss-sang.github.io/ssq-ui/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Miss-sang/ssq-ui.git"
  },
  "bugs": {
    "url": "https://github.com/Miss-sang/ssq-ui/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "component-library",
    "typescript",
    "vite",
    "vitepress",
    "design-system",
    "theme"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/lib/index.js",
  "module": "dist/es/index.mjs",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css",
    "dist/es/style.mjs",
    "dist/es/*Style.mjs",
    "dist/lib/style.js",
    "dist/lib/*Style.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.mjs",
      "require": "./dist/lib/index.js"
    },
    "./style": {
      "types": "./dist/types/style.d.ts",
      "import": "./dist/es/style.mjs",
      "require": "./dist/lib/style.js"
    },
    "./button": {
      "types": "./dist/types/components/Button/index.d.ts",
      "import": "./dist/es/components/Button/index.mjs",
      "require": "./dist/lib/components/Button/index.js"
    },
    "./config-provider": {
      "types": "./dist/types/components/config-provider/index.d.ts",
      "import": "./dist/es/components/config-provider/index.mjs",
      "require": "./dist/lib/components/config-provider/index.js"
    },
    "./button/style": {
      "types": "./dist/types/components/Button/style.d.ts",
      "import": "./dist/es/buttonStyle.mjs",
      "require": "./dist/lib/buttonStyle.js"
    },
    "./dialog": {
      "types": "./dist/types/components/dialog/index.d.ts",
      "import": "./dist/es/components/dialog/index.mjs",
      "require": "./dist/lib/components/dialog/index.js"
    },
    "./dialog/style": {
      "types": "./dist/types/components/dialog/style.d.ts",
      "import": "./dist/es/dialogStyle.mjs",
      "require": "./dist/lib/dialogStyle.js"
    },
    "./icon": {
      "types": "./dist/types/components/icon/index.d.ts",
      "import": "./dist/es/components/icon/index.mjs",
      "require": "./dist/lib/components/icon/index.js"
    },
    "./icon/style": {
      "types": "./dist/types/components/icon/style.d.ts",
      "import": "./dist/es/iconStyle.mjs",
      "require": "./dist/lib/iconStyle.js"
    },
    "./input": {
      "types": "./dist/types/components/input/index.d.ts",
      "import": "./dist/es/components/input/index.mjs",
      "require": "./dist/lib/components/input/index.js"
    },
    "./input/style": {
      "types": "./dist/types/components/input/style.d.ts",
      "import": "./dist/es/inputStyle.mjs",
      "require": "./dist/lib/inputStyle.js"
    },
    "./select": {
      "types": "./dist/types/components/select/index.d.ts",
      "import": "./dist/es/components/select/index.mjs",
      "require": "./dist/lib/components/select/index.js"
    },
    "./select/style": {
      "types": "./dist/types/components/select/style.d.ts",
      "import": "./dist/es/selectStyle.mjs",
      "require": "./dist/lib/selectStyle.js"
    },
    "./space": {
      "types": "./dist/types/components/space/index.d.ts",
      "import": "./dist/es/components/space/index.mjs",
      "require": "./dist/lib/components/space/index.js"
    },
    "./space/style": {
      "types": "./dist/types/components/space/style.d.ts",
      "import": "./dist/es/spaceStyle.mjs",
      "require": "./dist/lib/spaceStyle.js"
    },
    "./theme": {
      "types": "./dist/types/theme/index.d.ts",
      "import": "./dist/es/theme/index.mjs",
      "require": "./dist/lib/theme/index.js"
    },
    "./es": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.mjs"
    },
    "./lib": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/lib/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "preview": "vite preview",
    "lint": "node ./scripts/run-eslint.mjs",
    "lint:fix": "node ./scripts/run-eslint.mjs --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "perf:report": "node ./scripts/perf-report.mjs",
    "perf:smoke": "node ./scripts/perf-smoke.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release:check": "npm run lint && npm run typecheck && npm test -- --run && npm run build && npm run docs:build && npm run perf:smoke && npm pack --dry-run"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.11"
  },
  "peerDependencies": {
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-eslint": "^1.8.1",
    "vitepress": "^1.6.4",
    "vitepress-theme-demoblock": "^3.1.3",
    "vitest": "^4.0.18",
    "vue": "^3.5.25",
    "vue-tsc": "^3.1.5"
  }
}
